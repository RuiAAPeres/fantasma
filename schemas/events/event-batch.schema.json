{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fantasma.dev/schemas/events/event-batch.schema.json",
  "title": "Fantasma Event Batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "events"
  ],
  "properties": {
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "./mobile-event.schema.json"
      }
    }
  }
}
