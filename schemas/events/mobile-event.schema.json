{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fantasma.dev/schemas/events/mobile-event.schema.json",
  "title": "Fantasma Mobile Event",
  "description": "Install-scoped mobile event contract for Fantasma.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "timestamp",
    "install_id",
    "platform"
  ],
  "properties": {
    "event": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "install_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable install-scoped client identity used by ingest and backend sessionization. It is not a person identifier and it is not a public metrics query dimension."
    },
    "platform": {
      "type": "string",
      "enum": [
        "ios",
        "android"
      ]
    },
    "app_version": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Optional built-in app version."
    },
    "os_version": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Optional built-in OS version. First-party SDKs populate it when supported."
    },
    "properties": {
      "type": "object",
      "maxProperties": 4,
      "propertyNames": {
        "allOf": [
          {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{0,62}$"
          },
          {
            "not": {
              "enum": [
                "project_id",
                "event",
                "timestamp",
                "install_id",
                "properties",
                "start_date",
                "end_date",
                "group_by",
                "platform",
                "app_version",
                "os_version"
              ]
            }
          }
        ]
      },
      "additionalProperties": {
        "type": "string"
      },
      "description": "Explicit string event context, capped at 4 keys. The cap is a deliberate performance boundary for Fantasma's bounded worker-built aggregates. Reserved query and built-in keys are rejected, and properties must not be used to reconstruct person-level identity."
    }
  }
}
