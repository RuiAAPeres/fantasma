FROM rust:1.92-bookworm AS builder
WORKDIR /app

COPY Cargo.toml Cargo.toml
COPY crates crates

RUN cargo build --release -p fantasma-api

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/fantasma-api /usr/local/bin/fantasma-api

EXPOSE 8082
CMD ["/usr/local/bin/fantasma-api"]
